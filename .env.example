# Copy this file to .env and fill in the values. Ask a teammate for the
# current dev credentials; do not check secrets into the repo.

# ---- Core server ----
NODE_ENV=development
PORT=5000
PUBLIC_BASE_URL=http://localhost:5000

# ---- Database ----
DATABASE_URL=
# Optional: pg pool max connections per task (default 25) and stats log
# interval in ms (default 30000). Bump DB_POOL_MAX if you see waiting > 0
# sustained in the db.pool.stats logs.
DB_POOL_MAX=
DB_POOL_STATS_INTERVAL_MS=

# ---- Auth ----
PRIVY_APP_ID=
PRIVY_APP_SECRET=
VITE_PRIVY_APP_ID=

# ---- Payments ----
# Stripe handles all user-facing billing (credit top-ups at $7/turn or
# $70 for a 10-pack). Set STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET in
# prod via Secrets Manager. ENABLE_STRIPE=1 to activate.
ENABLE_STRIPE=0
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Daily LLM spend ceiling per user (USD). Belt-and-suspenders alongside
# the credit-gate. Default $20.
USER_DAILY_COST_CEILING_USD=

# ---- LLM provider ----
# All LLM calls go through OpenRouter. The MPP on-chain payment-channel
# provider was retired 2026-05-19 in favour of Stripe + credit-gate.
OPENROUTER_API_KEY=

# ---- External APIs ----
DUNE_API_KEY=
DEFILLAMA_PRO_API_KEY=
STONKS_API_KEY=
VOYAGE_API_KEY=

# ---- Notifications ----
TELEGRAM_BOT_TOKEN=

# ---- Observability ----
# Leave SENTRY_DSN unset locally and the SDK no-ops. Inject via Secrets
# Manager in prod. SENTRY_TRACES_SAMPLE_RATE defaults to 0.1 (10%).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=
LOG_LEVEL=

# ---- Feature flags ----
DEEP_RESEARCH_PARALLEL=0
