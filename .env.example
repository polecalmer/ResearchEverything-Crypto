# ---- Core server ----
NODE_ENV=development
PORT=5000
# Base URL the server is reachable at (no trailing slash). Used for building webhook/callback URLs.
PUBLIC_BASE_URL=http://localhost:5000

# ---- Database (Supabase Postgres) ----
# Dev Supabase project URI on localhost; prod URI lives in the deployment's secret store.
DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# ---- Auth (Privy) ----
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Inlined into the client bundle at build time by Vite.
VITE_PRIVY_APP_ID=

# ---- MPP (payment channel for Anthropic via Tempo) ----
# Private key of the server wallet — used to pay upstream (Anthropic, Allium) via MPP.
MPP_SERVER_WALLET_KEY=
# Used by the mppx server middleware (server/mpp.ts) to charge users on paywalled endpoints.
MPP_SECRET_KEY=

# ---- External APIs ----
DUNE_API_KEY=
DEFILLAMA_PRO_API_KEY=
STONKS_API_KEY=
VOYAGE_API_KEY=

# ---- Telegram (disabled on localhost — leave blank) ----
TELEGRAM_BOT_TOKEN=

# ---- Feature flags ----
# 1 = enable 3-phase parallel deep-research pipeline (higher burn, faster wall-clock)
# 0 = sequential (default on localhost for easier debugging)
DEEP_RESEARCH_PARALLEL=0

# 1 = initialize Stripe on startup (prod). 0 = skip Stripe entirely (localhost default).
ENABLE_STRIPE=0
# 1 = route research-agent Anthropic calls through the non-streaming endpoint.
# Set on localhost/home networks where the MPP stream is unstable. 0 in prod.
MPP_NO_STREAMING=0
