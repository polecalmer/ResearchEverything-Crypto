# Copy this file to .env and fill in the values. Ask a teammate for the
# current dev credentials; do not check secrets into the repo.

# ---- Core server ----
NODE_ENV=development
PORT=5000
PUBLIC_BASE_URL=http://localhost:5000

# ---- Database ----
DATABASE_URL=

# ---- Auth ----
PRIVY_APP_ID=
PRIVY_APP_SECRET=
VITE_PRIVY_APP_ID=

# ---- Payments ----
MPP_SERVER_WALLET_KEY=
MPP_SECRET_KEY=

# ---- External APIs ----
DUNE_API_KEY=
DEFILLAMA_PRO_API_KEY=
STONKS_API_KEY=
VOYAGE_API_KEY=

# ---- Notifications ----
TELEGRAM_BOT_TOKEN=

# ---- Feature flags ----
DEEP_RESEARCH_PARALLEL=0
ENABLE_STRIPE=0
MPP_NO_STREAMING=0
