# Copy this file to .env and fill in the values. Ask a teammate for the
# current dev credentials; do not check secrets into the repo.

# ---- Core server ----
NODE_ENV=development
PORT=5000
PUBLIC_BASE_URL=http://localhost:5000

# ---- Database ----
DATABASE_URL=
# Optional: pg pool max connections per task (default 25) and stats log
# interval in ms (default 30000). Bump DB_POOL_MAX if you see waiting > 0
# sustained in the db.pool.stats logs.
DB_POOL_MAX=
DB_POOL_STATS_INTERVAL_MS=

# ---- Auth ----
PRIVY_APP_ID=
PRIVY_APP_SECRET=
VITE_PRIVY_APP_ID=

# ---- Payments ----
MPP_SERVER_WALLET_KEY=
MPP_SECRET_KEY=
# Per-channel deposit cap in USDC (default 60). Bump if deep-research
# sessions exhaust the channel mid-flight ("14 sources, need one more
# pass" or "wallet needs to be topped up" surfaces).
MPP_DEPOSIT_CAP_USD=

# ---- External APIs ----
DUNE_API_KEY=
DEFILLAMA_PRO_API_KEY=
STONKS_API_KEY=
VOYAGE_API_KEY=

# ---- Notifications ----
TELEGRAM_BOT_TOKEN=

# ---- Observability ----
# Leave SENTRY_DSN unset locally and the SDK no-ops. Inject via Secrets
# Manager in prod. SENTRY_TRACES_SAMPLE_RATE defaults to 0.1 (10%).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=
LOG_LEVEL=

# ---- Feature flags ----
DEEP_RESEARCH_PARALLEL=0
ENABLE_STRIPE=0
MPP_NO_STREAMING=0
