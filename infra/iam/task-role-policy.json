{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ArtifactsBucketReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::<S3_BUCKET>/artifacts/*"
    },
    {
      "Sid": "ArtifactsBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::<S3_BUCKET>",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "artifacts/*"
          ]
        }
      }
    }
  ]
}
